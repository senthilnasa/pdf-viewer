# ---------------------------------------------------------------
# PDF Viewer Platform — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ---------------------------------------------------------------

# Application
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# Database
DB_NAME=pdf_viewer
DB_USER=pdfviewer
DB_PASS=changeme_strong_password
DB_ROOT_PASS=changeme_root_password
DB_PORT_EXPOSE=3306

# phpMyAdmin (optional, only used with --profile tools)
PMA_PORT=8081
